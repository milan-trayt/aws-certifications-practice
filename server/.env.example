# =============================================================================
# Server Environment Configuration
# Copy this file to .env and update with your actual values
# =============================================================================

# ---- Database ----
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/aws_practice
# DB_SSL_REJECT_UNAUTHORIZED=false   # uncomment for production / RDS

# ---- JWT ----
JWT_SECRET=                 # REQUIRED — generate with: openssl rand -base64 32
JWT_EXPIRES_IN=24h

# ---- CSRF ----
CSRF_SECRET=                # Optional — falls back to JWT_SECRET if empty

# ---- Amazon Cognito ----
COGNITO_USER_POOL_ID=       # e.g. us-east-1_AbCdEfGhI
COGNITO_CLIENT_ID=          # App client ID from Cognito console
AWS_REGION=us-east-1

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000

# ---- API Base URL ----
API_BASE_URL=http://localhost:5000
