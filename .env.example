# =============================================================================
# Environment Variables — copy to .env and fill in real values
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=          # REQUIRED — set a strong password
POSTGRES_DB=aws_practice

# ---- Database URL (used by the server) ----
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5432/aws_practice

# ---- JWT ----
JWT_SECRET=                 # REQUIRED — generate with: openssl rand -base64 32
JWT_EXPIRES_IN=24h

# ---- CSRF ----
CSRF_SECRET=                # Optional — falls back to JWT_SECRET if empty

# ---- Amazon Cognito ----
COGNITO_USER_POOL_ID=       # e.g. us-east-1_AbCdEfGhI
COGNITO_CLIENT_ID=          # App client ID from Cognito console
AWS_REGION=us-east-1

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000

# ---- Client (React) ----
REACT_APP_API_URL=http://localhost:5000/api

# ---- Production Domain ----
DOMAIN=                     # e.g. aws.yourdomain.com (used by nginx + CORS in production)

# ---- Rate Limiting ----
ENABLE_RATE_LIMIT=false     # Set to "true" to enable rate limiting
